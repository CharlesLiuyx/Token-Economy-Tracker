{% from '_macros.j2' import badge with context %}
<div class="cards-row dc-cards">
  <section class="panel mini-card">
    <header class="panel-head"><h3 data-i18n="panel.dc.sites_title">{{ t('panel.dc.sites_title') | e }}</h3>{{ badge('epoch_datacenters') }}</header>
    <div class="panel-body"><p class="big-number">{{ epoch_cards.sites }}</p>
      <p class="mini-sub" data-i18n="panel.dc.sites_sub">{{ t('panel.dc.sites_sub') | e }}</p></div>
  </section>
  <section class="panel mini-card">
    <header class="panel-head"><h3>Power</h3>{{ badge('epoch_datacenters') }}</header>
    <div class="panel-body"><p class="big-number">{{ epoch_cards.power_gw }} <span class="unit">GW</span></p>
      <p class="mini-sub" data-i18n="panel.dc.power_sub">{{ t('panel.dc.power_sub') | e }}</p></div>
  </section>
  <section class="panel mini-card">
    <header class="panel-head"><h3 data-i18n="panel.dc.compute_title">{{ t('panel.dc.compute_title') | e }}</h3>{{ badge('epoch_datacenters') }}</header>
    <div class="panel-body"><p class="big-number">{{ epoch_cards.h100_m }}M <span class="unit">H100-eq</span></p>
      <p class="mini-sub" data-i18n="panel.dc.compute_sub">{{ t('panel.dc.compute_sub') | e }}</p></div>
  </section>
  <section class="panel mini-card">
    <header class="panel-head"><h3 data-i18n="panel.dc.capex_title">{{ t('panel.dc.capex_title') | e }}</h3>{{ badge('epoch_datacenters') }}</header>
    <div class="panel-body"><p class="big-number">${{ '%.0f' | format(epoch_cards.capex_busd) }}B</p>
      <p class="mini-sub" data-i18n="panel.dc.capex_sub">{{ t('panel.dc.capex_sub') | e }}</p></div>
  </section>
</div>
