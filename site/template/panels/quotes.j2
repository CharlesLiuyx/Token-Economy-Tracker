{% from '_macros.j2' import panel_head with context %}
<section class="panel">
  {{ panel_head('KOL / Podcast — 专家观点摘录', 'yellow', 'manual') }}
  <div class="panel-body">
    {% if quotes %}
    <ul class="quote-list">
      {% for q in quotes %}
      <li>
        <p class="quote-text">“{{ q.quote | e }}”</p>
        <p class="quote-meta">— {{ q.speaker | e }}{% if q.role %}，{{ q.role | e }}{% endif %}
          · {{ q.date }}{% if q.source_url %} · <a href="{{ q.source_url | e }}">source</a>{% endif %}</p>
      </li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="empty-note">暂无收录。人工维护 <code>data/manual/quotes.yml</code>，
       收录标准：少量高质量原文摘录（见 PLAN §11 开放问题）。</p>
    {% endif %}
  </div>
</section>
