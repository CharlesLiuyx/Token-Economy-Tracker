<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="color-scheme" content="light dark">
<title>AI MONETIZATION TRACKER</title>
<script>
/* 首帧前设定主题与语言，防白闪：localStorage 覆盖 > 系统偏好（语言默认 zh，浏览器非中文则 en） */
(function () {
  var t = null, l = null;
  try { t = localStorage.getItem("theme"); l = localStorage.getItem("lang"); } catch (e) {}
  if (t !== "light" && t !== "dark")
    t = matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
  if (l !== "zh" && l !== "en")
    l = /^zh/i.test(navigator.language || "") ? "zh" : "en";
  var root = document.documentElement;
  root.dataset.theme = t;
  root.dataset.lang = l;
  if (l === "en") root.lang = "en";
})();
</script>
<style>
{{ style }}
</style>
</head>
<body>

<header class="topbar">
  <div class="topbar-inner">
    <a class="brand" href="#top">AI Monetization Tracker</a>
    <nav class="topnav">
      <a href="#sec-arr">ARR</a>
      <a href="#sec-tokens">Tokens</a>
      <a href="#sec-gpu">GPU</a>
      <a href="#sec-dc">Datacenters</a>
      <a href="#sec-methodology">Methodology</a>
    </nav>
    <span class="build-ts">BUILD {{ build_ts }}</span>
    <a class="icon-btn" href="https://github.com/CharlesLiuyx/Token-Economy-Tracker"
       target="_blank" rel="noopener noreferrer"
       aria-label="{{ t('ui.github') | e }}" title="{{ t('ui.github') | e }}"
       data-i18n-aria-label="ui.github" data-i18n-title="ui.github">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.49 5.92.43.37.82 1.1.82 2.22 0 1.61-.02 2.9-.02 3.29 0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/>
      </svg>
    </a>
    <button id="lang-toggle" class="icon-btn lang-btn" type="button"
            aria-label="{{ t('ui.lang_toggle') | e }}" title="{{ t('ui.lang_toggle') | e }}"
            data-i18n-aria-label="ui.lang_toggle" data-i18n-title="ui.lang_toggle">EN</button>
    <button id="theme-toggle" class="icon-btn" type="button"
            aria-label="{{ t('ui.theme_toggle') | e }}" title="{{ t('ui.theme_toggle') | e }}"
            data-i18n-aria-label="ui.theme_toggle" data-i18n-title="ui.theme_toggle">
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"/>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
      </svg>
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>
      </svg>
    </button>
  </div>
</header>

<main id="top">
  <div class="page-head">
    <h1>AI Monetization Tracker</h1>
    <p class="tagline" data-i18n="ui.tagline">{{ t('ui.tagline') | e }}</p>
    <p class="source-line">
      {%- for name, st in source_status.items() %}
      {%- set date = st.snapshot_date or '—' %}
      <span class="badge badge-{{ st.freshness or 'missing' }}"
            {%- if st.error %} title="{{ st.error | e }}"
            {%- else %} title="{{ t('ui.data_asof', date=date) | e }}" data-i18n-title="ui.data_asof"
            data-i18n-args='{{ {"date": date} | tojson }}'{% endif %}>{{ name }} · {{ date }}</span>
      {%- endfor %}
    </p>
  </div>

  <section class="section" id="sec-arr">
    <h2 class="section-title"><span class="section-index si-arr">01</span>Frontier Lab ARR
      <span class="section-sub" data-i18n="sec.arr.sub">{{ t('sec.arr.sub') | e }}</span></h2>
    {% include 'panels/arr_cards.j2' %}
    {% include 'panels/arr_chart.j2' %}
  </section>

  <section class="section" id="sec-tokens">
    <h2 class="section-title"><span class="section-index si-tokens">02</span><span
        data-i18n="sec.tokens.title">{{ t('sec.tokens.title') | e }}</span>
      <span class="section-sub">OpenRouter · Vercel Gateway · SDK</span></h2>
    <div class="grid2">
      {% include 'panels/or_tracked.j2' %}
      {% include 'panels/or_top_models.j2' %}
      {% include 'panels/or_weekly_total.j2' %}
      {% include 'panels/sdk.j2' %}
      {% include 'panels/vercel_tokens.j2' %}
      {% include 'panels/vercel_cost.j2' %}
      {% include 'panels/vercel_trend.j2' %}
      {% include 'panels/quotes.j2' %}
    </div>
    {% include 'panels/epoch_sites.j2' %}
  </section>

  <section class="section" id="sec-gpu">
    <h2 class="section-title"><span class="section-index si-gpu">03</span><span
        data-i18n="sec.gpu.title">{{ t('sec.gpu.title') | e }}</span>
      <span class="section-sub" data-i18n="sec.gpu.sub">{{ t('sec.gpu.sub') | e }}</span></h2>
    {% include 'panels/gpu_cards.j2' %}
    {% include 'panels/gpu_trend.j2' %}
  </section>

  <section class="section" id="sec-dc">
    <h2 class="section-title"><span class="section-index si-dc">04</span><span
        data-i18n="sec.dc.title">{{ t('sec.dc.title') | e }}</span>
      <span class="section-sub">Epoch AI + News</span></h2>
    {% include 'panels/dc_cards.j2' %}
    {% include 'panels/dc_growth.j2' %}
    {% include 'panels/news.j2' %}
  </section>

  {% include 'panels/methodology.j2' %}
</main>

<footer class="footer">
  <p data-i18n="ui.footer">{{ t('ui.footer') | e }}</p>
</footer>

<script id="dashboard-data" type="application/json">{{ dashboard_json }}</script>
<script id="i18n-data" type="application/json">{{ i18n_json }}</script>
<script>
{{ chart_js }}
</script>
<script>
{{ app_js }}
</script>
</body>
</html>
